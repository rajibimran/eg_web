# Frontend SPA only — this file is read by Vite when you run/build the React app. Strapi (backend) does not use these keys.

# Copy to .env and fill in. Never commit real secrets.

# Local dev with eg_admin: use port 1338 (see eg_admin/.env PORT)
VITE_STRAPI_URL=http://127.0.0.1:1338
VITE_STRAPI_API_KEY=your-strapi-read-only-api-token

# Mock / demo rows bundled inside the **frontend** (src/data, etc.). Strapi server is unchanged.
# Vite only exposes variables prefixed with VITE_.
# Yes (default) = the SPA may show those rows when Strapi has no URL, a request fails, or a collection is empty.
# No = the SPA never shows that bundled mock data; empty CMS fields and empty lists stay empty.
VITE_MOCK_DATA=Yes

# eg_web does not mount /staff/lab-reports; patient report check on /reports still uses the same Strapi APIs when configured.
